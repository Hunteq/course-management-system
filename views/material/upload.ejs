<%- include('../layouts/main', { title: 'Upload Material' }) %>
<h1>Upload Material</h1>

<form action="/material/upload" method="POST" enctype="multipart/form-data">
  <div class="form-group">
    <label for="title">Material Title</label>
    <input type="text" id="title" name="title" required>
  </div>

  <div class="form-group">
    <label for="batch">Batch Selection</label>
    <select id="batch" name="batch" required>
      <option value="">Select Batch</option>
      <% batches.forEach(batch => { %>
        <option value="<%= batch._id %>"><%= batch.name %></option>
      <% }); %>
    </select>
  </div>

  <div class="form-group">
    <label>Upload your file here</label>
    <div class="upload-box">
      <input type="file" name="materialFile" id="materialFile" required>
      <p>Supported formats: PDF, JPEG, JPG, PNG</p>
    </div>
  </div>

  <button type="submit" class="btn btn-primary">Upload</button>
</form>